GOOGLE_API_KEY=your-api-key-here

# Optional: override the Gemini model (default: gemini-2.5-flash-lite)
# Alternative: gemini-2.5-flash (smarter, but only 10 RPM on free tier)
# Full model list: https://ai.google.dev/gemini-api/docs/models
# GEMINI_MODEL=gemini-2.5-flash

# Optional: override the Ollama fallback model (default: qwen2.5:3b)
# Alternative:
#   OLLAMA_MODEL=llama3.1:8b   (best quality, needs 16GB+ RAM)
